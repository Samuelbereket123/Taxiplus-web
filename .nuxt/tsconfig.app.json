{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "paths": {
            "#app": [
                "../node_modules/nuxt/dist/app"
            ],
            "#app/*": [
                "../node_modules/nuxt/dist/app/*"
            ],
            "~/*": [
                "..",
                "../*"
            ],
            "@/*": [
                "..",
                "../*"
            ],
            "~~/*": [
                "..",
                "../*"
            ],
            "@@/*": [
                "..",
                "../*"
            ],
            "assets/*": [
                "../assets/*"
            ],
            "public/*": [
                "../public/*"
            ],
            "#build": [
                "."
            ],
            "#build/*": [
                "./*"
            ]
        }
    },
    "include": [
        "./nuxt.d.ts",
        "../**/*",
        "../.nuxt/types/**/*"
    ],
    "exclude": [
        "../node_modules",
        "../dist"
    ]
}